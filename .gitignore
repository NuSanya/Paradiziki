#ignore misc BYOND files
Thumbs.db
*.log
*.int
*.rsc
*.mdme
*.mdme.*
*.m.dme
*.test.dme
*.dmb
*.lk
*.backup
*.dmm.before
*.cache
*.pyc
data/
!data/logs/.keep
!data/mode.txt
cfg/
tmp/
/cache/**/*
tools/Runtime Condenser/Input.txt
tools/Runtime Condenser/Output.txt
tools/MapDaemon/logs/*.txt
fast_paradise.dme

#Visual studio stuff
*.vscode/*
!/.vscode/extensions.json
!/.vscode/launch.json
!/.vscode/tasks.json

#ignore any files in config/, except those in subdirectories.
/config/*
!config/**/*/
!config/emojis.txt
!config/events.txt
!config/game_modes.txt
!config/logs.txt
!config/maps.txt
!config/donations_text.txt
!config/jobs_highpop.txt
!config/jobs.txt
!config/admin_ranks.txt

# ignore cfg, an internal BYOND folder
/cfg/*

#ignore other, specific files and folers
*.before
/_maps/map_files/backup/*
/_maps/map_files/**/backup/*
/_maps/map_files/**/*.dmm.backup
/_maps/quicksave/*
**/__pycache__/*
*.db
stddef.dm
.atom-build.json
.idea/
*/node_modules/*

/tools/bootstrap/.cache/

# ignore DMI tool build cache
/tools/dmitool/bin/
/tools/dmitool/.gradle/
/tools/dmitool/.settings/
/tools/dmitool/.classpath
/tools/dmitool/.project

# ignore midi2piano build cache
/tools/midi2piano/midi2piano/obj/*

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# ignore python cache
.cache

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# pyenv
.python-version

# Ignore compiled dynamic libs in the root folder, e.g. librust_g.so
/*.so
/*.dll

#Ignore cached sound files.
/sound/tts_cache/**/*
/sound/tts_scrambled/**/*
.gitignore

# Rust output.
/rust/target/*

# Tools some of us like to keep in the repo
OpenDream
paradise.json

# dmdoc and output
dmdoc.exe
dmdoc/
